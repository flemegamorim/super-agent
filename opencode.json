{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "permission": {
    "bash": "allow",
    "edit": "allow"
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "cors": [
      "*"
    ]
  },
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Orchestrates file processing pipelines: ingests files, runs analysis, generates output",
      "prompt": "{file:./prompts/build.txt}",
      "tools": {
        "bash": true,
        "write": true,
        "edit": true
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "output/**",
      "web/**"
    ]
  }
}
